{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git rm:*)",
      "Bash(git commit:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rm:*)",
      "Bash(mkdir:*)",
      "Bash(echo $XDG_RUNTIME_DIR)",
      "Bash(export:*)",
      "Bash(node --version)",
      "Bash(node -e:*)",
      "Bash(node -p:*)",
      "Bash(node:*)",
      "Bash(nvm ls-remote:*)",
      "Bash(nvm install:*)",
      "Bash(nvm use:*)",
      "Bash(source ~/.nvm/nvm.sh)",
      "Bash(nvm alias:*)",
      "Bash(nvm current:*)",
      "Bash(git add:*)",
      "Bash(lsof:*)",
      "Bash(cat:*)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:neovim.io)",
      "WebFetch(domain:linkarzu.com)",
      "WebFetch(domain:www.npmjs.com)",
      "WebFetch(domain:deepwiki.com)"
    ],
    "deny": []
  }
}
